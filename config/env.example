# ===========================
# Claude Telegram Relay — Environment Configuration
# ===========================
# Copy this file to .env in the project root (or run install.sh to generate it).

# ----- Required -----

# Telegram bot token from @BotFather (https://t.me/BotFather)
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Comma-separated Telegram user IDs allowed to use the bot.
# Find your ID by messaging @userinfobot on Telegram.
ALLOWED_USER_IDS=YOUR_TELEGRAM_USER_ID

# ----- Optional: Claude CLI -----

# Path to the claude binary. Auto-detected if empty.
CLAUDE_PATH=

# Working directory for Claude CLI. Determines which CLAUDE.md context is loaded.
# Defaults to $HOME if empty.
WORKING_DIR=

# Model override (e.g., sonnet, opus, haiku). Empty = Claude Code default.
CLAUDE_MODEL=

# Per-message timeout in milliseconds. Default: 120000 (2 min).
# Increase for deep research tasks (e.g., 480000 = 8 min).
CLAUDE_TIMEOUT_MS=120000

# ----- Optional: Bot behavior -----

# Max queued messages per chat before rejecting new ones. Default: 5.
MESSAGE_QUEUE_MAX=5

# Group chat behavior: "mention" = respond to @botname only, "all" = respond to everything.
GROUP_MODE=mention

# Notify allowed users when bot starts/restarts. Default: false.
SEND_STARTUP_MESSAGE=false

# Log level: debug, info, warn, error. Default: info.
LOG_LEVEL=info

# ----- Optional: v1.4.0 features -----

# Inline keyboard buttons under Claude responses. Set to "false" to disable.
# When enabled (default), every response ends with [+ New] [💾 Save] [ℹ Info]
# tappable buttons so you can clear/label/inspect the current session in one tap.
INLINE_KEYBOARDS=true

# ----- Optional: OpenClaw memory integration -----
# (only used if you have OpenClaw / FlipClaw installed alongside Claude Code)

# Path to your OpenClaw config file. Auto-detected from ~/.openclaw/openclaw.json
# if empty. Set this explicitly if your OpenClaw lives elsewhere (e.g. Ari users
# typically point this at /home/ubuntu/ari/openclaw.json).
OPENCLAW_CONFIG_PATH=

# Path to the openclaw binary. Defaults to "openclaw" on PATH if empty.
OPENCLAW_BIN=

# Working directory for the openclaw subprocess. Defaults to the directory
# containing OPENCLAW_CONFIG_PATH if empty.
OPENCLAW_CWD=

# Timeout for /memory searches in milliseconds. Default: 90000 (90s).
# A cold query against a large semantic memory index (e.g. Ari's Gemini+LanceDB
# setup) legitimately takes 30–90s the first time as embeddings/indexes warm
# up. Subsequent queries are much faster. Increase if you see timeouts on
# the first query after a bot restart.
OPENCLAW_SEARCH_TIMEOUT_MS=

# ----- Optional: Outbound messaging helper (v1.3.0+) -----

# Default chat ID for outbound messages sent via scripts/send-message.sh
# or lib/send-message.js. If empty, the first ID in ALLOWED_USER_IDS is used.
DEFAULT_CHAT_ID=

# ----- Optional: v1.5.0 update checker -----

# Notify the admin (first ALLOWED_USER_IDS entry) when a new release is
# published on GitHub. Runs once on startup, then every 24 hours.
# The check never auto-upgrades — it just sends a one-time Telegram
# message with the release notes and a link, so you can decide.
# Set to "false" to disable entirely. Default: true.
UPDATE_CHECK=true

# ----- Optional: v1.7.0 live streaming -----

# Show live status (🤔 Thinking → 📖 Using Read → 📝 Replying) by editing a
# single Telegram message in place as Claude works, instead of waiting
# for the full response and sending it all at once. Dramatic UX
# improvement on a phone, especially for tool-heavy tasks. Set to
# "false" to fall back to the v1.6.0 synchronous path. Default: true.
STREAMING=true
